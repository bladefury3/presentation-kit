#!/usr/bin/env bash
set -euo pipefail

# ─── Presentation Kit Installer ─────────────────────────────────────────
# Installs presentation skills for AI coding tools (Claude Code, Cursor, etc.).
# Usage: ./setup [--local] [--cursor] [--update] [--uninstall]
# ─────────────────────────────────────────────────────────────────────────

VERSION=$(cat "$(dirname "$0")/VERSION")
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Colors ──────────────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
RESET='\033[0m'

# ─── Helpers ─────────────────────────────────────────────────────────────
info()  { echo -e "${BLUE}→${RESET} $1"; }
ok()    { echo -e "${GREEN}✓${RESET} $1"; }
warn()  { echo -e "${YELLOW}!${RESET} $1"; }
fail()  { echo -e "${RED}✗${RESET} $1"; exit 1; }
dim()   { echo -e "${DIM}  $1${RESET}"; }

header() {
  echo ""
  echo -e "${BOLD}presentation-kit${RESET} ${DIM}v${VERSION}${RESET}"
  echo -e "${DIM}Presentation skills for Figma Slides via the figma-console MCP${RESET}"
  echo ""
}

# ─── Parse args ──────────────────────────────────────────────────────────
LOCAL=false
UNINSTALL=false
UPDATE=false
CURSOR=false
CURSOR_DIR=""

for arg in "$@"; do
  case "$arg" in
    --local)     LOCAL=true ;;
    --uninstall) UNINSTALL=true ;;
    --update)    UPDATE=true ;;
    --cursor)    CURSOR=true ;;
    --cursor=*)  CURSOR=true; CURSOR_DIR="${arg#--cursor=}" ;;
    --help|-h)
      header
      echo "Usage: ./setup [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --local         Install to .claude/commands/ in current directory"
      echo "  --cursor        Install to .cursor/skills/ in current directory"
      echo "  --cursor=/path  Install to a specific project's .cursor/skills/"
      echo "  --update        Pull latest version from git, then reinstall"
      echo "  --uninstall     Remove installed skills"
      echo "  -h, --help      Show this help"
      echo ""
      echo "Examples:"
      echo "  ./setup                          # Global install (Claude Code)"
      echo "  ./setup --local                  # Project-local install"
      echo "  ./setup --cursor                 # Install as Cursor skills (current dir)"
      echo "  ./setup --cursor=/path/to/proj   # Install to another project's Cursor"
      echo "  ./setup --update                 # Pull latest + reinstall everywhere"
      echo ""
      exit 0
      ;;
    *) fail "Unknown option: $arg" ;;
  esac
done

# ─── Update ──────────────────────────────────────────────────────────────
if [ "$UPDATE" = true ]; then
  header

  if [ ! -d "$SCRIPT_DIR/.git" ]; then
    fail "Not a git repository. Clone presentation-kit with git to enable updates."
  fi

  cd "$SCRIPT_DIR"

  OLD_VERSION="$VERSION"
  OLD_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")

  if ! git diff --quiet 2>/dev/null; then
    warn "You have local changes. Stashing them before update..."
    git stash --quiet
    STASHED=true
  else
    STASHED=false
  fi

  info "Checking for updates..."
  git fetch --quiet origin 2>/dev/null || fail "Could not reach remote. Check your network."

  LOCAL_HEAD=$(git rev-parse HEAD)
  REMOTE_HEAD=$(git rev-parse origin/main 2>/dev/null || git rev-parse origin/master 2>/dev/null || echo "")

  if [ -z "$REMOTE_HEAD" ]; then
    fail "Could not find remote branch (tried origin/main and origin/master)."
  fi

  if [ "$LOCAL_HEAD" = "$REMOTE_HEAD" ]; then
    ok "Already up to date (v${VERSION})"
    echo ""

    if [ "$STASHED" = true ]; then
      git stash pop --quiet
      dim "Restored your local changes"
    fi

    if [ "$CURSOR" = true ]; then
      info "Reinstalling Cursor skills..."
    else
      info "Reinstalling skills..."
    fi
  else
    info "Updating from ${OLD_COMMIT} to $(git rev-parse --short $REMOTE_HEAD)..."
    git pull --ff-only --quiet origin 2>/dev/null || {
      warn "Fast-forward failed. Trying merge..."
      git pull --quiet origin 2>/dev/null || fail "Update failed. Resolve conflicts manually."
    }

    if [ "$STASHED" = true ]; then
      git stash pop --quiet 2>/dev/null || warn "Could not restore local changes. Run 'git stash pop' manually."
    fi

    VERSION=$(cat "$SCRIPT_DIR/VERSION")
    NEW_COMMIT=$(git rev-parse --short HEAD)

    ok "Updated: v${OLD_VERSION} → v${VERSION}"
    echo ""

    echo -e "${BOLD}What's new:${RESET}"
    echo ""

    CHANGED_SKILLS=$(git diff --name-only "${OLD_COMMIT}..${NEW_COMMIT}" -- '*/SKILL.md' 2>/dev/null | sed 's|/SKILL.md||' | sort)
    if [ -n "$CHANGED_SKILLS" ]; then
      while IFS= read -r skill; do
        if git diff --name-status "${OLD_COMMIT}..${NEW_COMMIT}" -- "${skill}/SKILL.md" 2>/dev/null | grep -q "^A"; then
          echo -e "  ${GREEN}+ new${RESET}  /${skill}"
        else
          echo -e "  ${CYAN}~ updated${RESET}  /${skill}"
        fi
      done <<< "$CHANGED_SKILLS"
    else
      dim "No skill changes"
    fi

    if git diff --name-only "${OLD_COMMIT}..${NEW_COMMIT}" -- 'PRINCIPLES.md' 2>/dev/null | grep -q .; then
      echo -e "  ${CYAN}~ updated${RESET}  PRINCIPLES.md"
    fi
    if git diff --name-only "${OLD_COMMIT}..${NEW_COMMIT}" -- 'README.md' 2>/dev/null | grep -q .; then
      echo -e "  ${CYAN}~ updated${RESET}  README.md"
    fi

    echo ""
  fi
fi

# ─── Determine install path ─────────────────────────────────────────────
if [ "$CURSOR" = true ]; then
  if [ -n "$CURSOR_DIR" ]; then
    INSTALL_DIR="${CURSOR_DIR}/.cursor/skills"
  else
    INSTALL_DIR="$(pwd)/.cursor/skills"
  fi
  INSTALL_MODE="cursor"
elif [ "$LOCAL" = true ]; then
  INSTALL_DIR="$(pwd)/.claude/commands"
  INSTALL_MODE="claude"
else
  INSTALL_DIR="$HOME/.claude/commands"
  INSTALL_MODE="claude"
fi

# ─── Uninstall ───────────────────────────────────────────────────────────
if [ "$UNINSTALL" = true ]; then
  header
  removed=false

  if [ "$INSTALL_MODE" = "cursor" ]; then
    for dir in "$SCRIPT_DIR"/*/; do
      if [ -f "$dir/SKILL.md" ]; then
        skill_name="$(basename "$dir")"
        target="$INSTALL_DIR/$skill_name"
        if [ -d "$target" ]; then
          rm -rf "$target"
          ok "Removed $target"
          removed=true
        fi
      fi
    done
  else
    for dir in "$SCRIPT_DIR"/*/; do
      if [ -f "$dir/SKILL.md" ]; then
        skill_name="$(basename "$dir")"
        if [ -f "$INSTALL_DIR/$skill_name.md" ]; then
          rm "$INSTALL_DIR/$skill_name.md"
          ok "Removed $INSTALL_DIR/$skill_name.md"
          removed=true
        fi
      fi
    done
  fi

  if [ "$removed" = false ]; then
    warn "Nothing to uninstall"
  fi
  exit 0
fi

# ─── Install ─────────────────────────────────────────────────────────────
if [ "$UPDATE" != true ]; then
  header
fi

# Discover skills (directories containing SKILL.md)
SKILLS=()
for dir in "$SCRIPT_DIR"/*/; do
  if [ -f "$dir/SKILL.md" ]; then
    skill_name="$(basename "$dir")"
    SKILLS+=("$skill_name")
  fi
done

if [ ${#SKILLS[@]} -eq 0 ]; then
  warn "No skills found yet. Phase 0 scaffolding is complete; skills are authored in Phase 1+."
  warn "Re-run ./setup after skills are added."
  exit 0
fi

info "Installing ${#SKILLS[@]} skills..."
echo ""

mkdir -p "$INSTALL_DIR"

NEW_COUNT=0
UPDATED_COUNT=0

# ─── Copy supporting files (shared/, build-helpers/, design-system/templates/) ─
SUPPORT_DIRS=(shared build-helpers design-system)
SUPPORT_FILES=(PRINCIPLES.md ETHOS.md)

for sdir in "${SUPPORT_DIRS[@]}"; do
  if [ -d "$SCRIPT_DIR/$sdir" ]; then
    target_dir="$INSTALL_DIR/$sdir"
    if [ -d "$target_dir" ]; then
      rm -rf "$target_dir"
    fi
    cp -r "$SCRIPT_DIR/$sdir" "$target_dir"
    dim "Copied $sdir/"
  fi
done

for sfile in "${SUPPORT_FILES[@]}"; do
  if [ -f "$SCRIPT_DIR/$sfile" ]; then
    cp "$SCRIPT_DIR/$sfile" "$INSTALL_DIR/$sfile"
    dim "Copied $sfile"
  fi
done

# Per-skill companion files (e.g., <skill>/REFERENCE.md)
for skill in "${SKILLS[@]}"; do
  for companion in "$SCRIPT_DIR/$skill"/*.md; do
    [ -f "$companion" ] || continue
    cname="$(basename "$companion")"
    [ "$cname" = "SKILL.md" ] && continue
    if [ "$INSTALL_MODE" = "cursor" ]; then
      mkdir -p "$INSTALL_DIR/$skill"
      cp "$companion" "$INSTALL_DIR/$skill/$cname"
      dim "Copied $skill/$cname"
    fi
  done
done

echo ""

for skill in "${SKILLS[@]}"; do
  skill_src="$SCRIPT_DIR/$skill/SKILL.md"

  if [ "$INSTALL_MODE" = "cursor" ]; then
    skill_dst="$INSTALL_DIR/$skill/SKILL.md"
    mkdir -p "$INSTALL_DIR/$skill"
  else
    skill_dst="$INSTALL_DIR/${skill}.md"
  fi

  if [ -f "$skill_dst" ]; then
    if cmp -s "$skill_src" "$skill_dst" 2>/dev/null; then
      dim "/$skill (unchanged)"
      continue
    fi
    UPDATED_COUNT=$((UPDATED_COUNT + 1))
    cp "$skill_src" "$skill_dst"
    ok "Updated ${BOLD}/$skill${RESET}"
  else
    NEW_COUNT=$((NEW_COUNT + 1))
    cp "$skill_src" "$skill_dst"
    ok "Installed ${BOLD}/$skill${RESET}"
  fi

  desc=$(sed -n '/^---$/,/^---$/d; /^#/d; /^$/d; p' "$skill_dst" | head -1 || true)
  if [ -n "$desc" ]; then
    dim "$desc"
  fi
done

echo ""

if [ "$INSTALL_MODE" = "cursor" ]; then
  ok "Installed to ${BOLD}${INSTALL_DIR}${RESET}"
else
  ok "Installed to ${BOLD}${INSTALL_DIR}${RESET}"
fi

echo ""
echo -e "${BOLD}Quick start:${RESET}"
echo ""
echo "  Open a Figma Slides file with the Desktop Bridge plugin running, then:"
echo ""
for skill in "${SKILLS[@]}"; do
  echo -e "    ${BLUE}/${skill}${RESET}"
done

echo ""
echo -e "${DIM}Skills require the figma-console MCP server to be connected.${RESET}"
echo -e "${DIM}Make sure your Figma Slides file is open with the Desktop Bridge plugin running.${RESET}"
echo ""

VERSION_FILE="$INSTALL_DIR/.presentation-kit-version"
echo "$VERSION" > "$VERSION_FILE"

if [ "$UPDATE" != true ]; then
  echo -e "${DIM}To update later: cd $(basename "$SCRIPT_DIR") && ./setup --update${RESET}"
  echo ""
fi
